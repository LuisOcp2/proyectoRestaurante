<?xml version="1.0" encoding="UTF-8"?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import io.github.palexdev.materialfx.controls.*?>

<!--
╔════════════════════════════════════════════════════════════════════════════╗
║  VistaAreasMesa.fxml  —  CRUD Áreas de Mesa                            ║
║                                                                          ║
║  Estructura basada en el diseño system "The Modern Maître D'"            ║
║  Campos mapeados a tabla: areas_mesa (BD restaurante_2026)              ║
║                                                                          ║
║  CONTRATO CONTROLADOR (AreasMesaController):                             ║
║    txtBuscarArea     → MFXTextField  búsqueda por nombre/descripción     ║
║    tblListaAreas     → TableView<AreaMesa>                               ║
║    lblConteoAreas    → Label conteo de resultados                        ║
║    txtAreaNombre     → MFXTextField  nombre                              ║
║    txtAreaDescripcion→ MFXTextField  descripción                         ║
║    cmbAreaEstado     → MFXComboBox<String> estado                        ║
║    lblMensajeArea    → Label mensajes de validación/resultado            ║
╚════════════════════════════════════════════════════════════════════════════╝
-->
<StackPane
    styleClass="root-container"
    stylesheets="@../styles/styles.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.mosqueteros.proyecto_restaurante.controller.AreasMesaController">

    <!-- Padding exterior: 32px en todos los lados -->
    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

    <HBox
        alignment="TOP_LEFT"
        fillHeight="true"
        maxHeight="Infinity"
        maxWidth="Infinity"
        spacing="24">

        <!-- COLUMNA IZQUIERDA  —  Título + Card con tabla -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" maxHeight="Infinity">

            <!-- Encabezado de sección con overline y título -->
            <VBox alignment="CENTER_LEFT" spacing="4">
                <Label text="ÁREAS DE MESA" styleClass="input-label"/>
                <Label styleClass="titulo-texto" text="Áreas de Mesa"/>
            </VBox>

            <!-- Card principal -->
            <VBox styleClass="main-card" VBox.vgrow="ALWAYS" maxHeight="Infinity" spacing="0">

                <!-- Barra filtros -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="filter-bar">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                    <HBox styleClass="search-wrapper" HBox.hgrow="ALWAYS" minWidth="200">
                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="icon-muted"/>
                        <MFXTextField
                            fx:id="txtBuscarArea"
                            promptText="Buscar por nombre o descripción..."
                            styleClass="search-field"
                            HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Filtro por estado -->
                    <VBox spacing="2">
                        <Label text="Estado" styleClass="input-label"/>
                        <MFXComboBox fx:id="cmbFiltroEstado"
                                  promptText="Todos los estados"
                                  prefWidth="120"
                                  styleClass="filtro-combo-nativo"/>
                    </VBox>

                    <!-- Botón buscar -->
                    <MFXButton fx:id="btnBuscarArea"
                               onAction="#buscarArea"
                               styleClass="btn-outline-primary"
                               text="Buscar">
                        <graphic><FontIcon iconLiteral="fas-search" iconSize="12"/></graphic>
                    </MFXButton>

                    <!-- Botón limpiar -->
                    <MFXButton fx:id="btnLimpiarFiltroArea"
                               onAction="#limpiarFiltros"
                               styleClass="btn-outline-secondary"
                               text="Limpiar">
                        <graphic><FontIcon iconLiteral="fas-sync" iconSize="12"/></graphic>
                    </MFXButton>
                </HBox>

                <!-- Cabecera de columnas -->
                <HBox styleClass="table-header-row">
                    <Label text="ID" styleClass="col-header" prefWidth="60"/>
                    <Label text="Nombre" styleClass="col-header" HBox.hgrow="ALWAYS"/>
                    <Label text="Descripción" styleClass="col-header" HBox.hgrow="ALWAYS"/>
                    <Label text="Estado" styleClass="col-header" prefWidth="80"/>
                </HBox>

                <!-- Tabla -->
                <VBox VBox.vgrow="ALWAYS" spacing="0">
                    <TableView fx:id="tblListaAreas" styleClass="mesas-table">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colIdArea" prefWidth="60" text="ID" />
                            <TableColumn fx:id="colNombre" prefWidth="150" text="NOMBRE" />
                            <TableColumn fx:id="colDescripcion" prefWidth="200" text="DESCRIPCIÓN" />
                            <TableColumn fx:id="colEstado" prefWidth="80" text="ESTADO" />
                        </columns>
                    </TableView>

                    <!-- Estado vacío -->
                    <VBox fx:id="boxPlaceholder" alignment="CENTER" spacing="16"
                          visible="true" managed="true" styleClass="empty-state">
                        <FontIcon iconLiteral="fas-map-marked-alt" iconSize="48" styleClass="icon-muted"/>
                        <Label text="No hay áreas de mesa registradas" styleClass="titulo-texto"/>
                        <Label text="Ajusta los filtros o agrega una nueva área." styleClass="conteo-label"/>
                    </VBox>
                </VBox>

                <!-- Footer tabla -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="table-footer">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>
                    <Label fx:id="lblConteoAreas" styleClass="conteo-label"
                           text="0 áreas encontradas" HBox.hgrow="ALWAYS"/>
                    <MFXButton fx:id="btnNuevoArea" onAction="#prepararNuevoArea"
                               styleClass="btn-raised-primary" text="Nueva Área">
                        <graphic><FontIcon iconLiteral="fas-plus" iconSize="12"/></graphic>
                    </MFXButton>
                </HBox>
            </VBox>
        </VBox>

        <!-- COLUMNA DERECHA  —  Formulario -->
        <VBox prefWidth="360" maxWidth="360" minWidth="320" spacing="0">

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="form-header">
                <padding><Insets top="20" right="24" bottom="20" left="24" /></padding>
                <StackPane styleClass="form-header-badge">
                    <FontIcon iconLiteral="fas-map-marked-alt" iconSize="18"/>
                </StackPane>
                <Label styleClass="form-header-titulo" text="Detalle de Área"/>
            </HBox>

            <!-- MFXScrollPane con import corregido -->
            <MFXScrollPane fitToWidth="true" fitToHeight="false"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="form-scroll">
                <VBox styleClass="main-card" spacing="0">

                    <VBox spacing="18">
                        <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>

                        <!-- Campo Pixel Perfect: Nombre -->
                        <VBox styleClass="pixel-field-block">
                            <StackPane fx:id="boxAreaNombreField" styleClass="pixel-field-container">
                                <HBox styleClass="field-icon-left" alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-map-marked-alt"/>
                                </HBox>
                                <MFXTextField fx:id="txtAreaNombre" promptText=" "
                                              styleClass="pixel-text-field"
                                              StackPane.alignment="CENTER_LEFT"/>
                                <Label text="Nombre" styleClass="floating-label" StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                            <Label fx:id="lblAreaNombreError" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                        </VBox>

                        <!-- Campo: Descripción -->
                        <VBox spacing="6">
                            <Label text="Descripción" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-sticky-note" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtAreaDescripcion" promptText="Descripción detallada"
                                              styleClass="input-field" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Combo Pixel Perfect: Estado -->
                        <VBox styleClass="pixel-field-block">
                            <StackPane fx:id="boxAreaEstadoField" styleClass="pixel-combo-container">
                                <HBox styleClass="field-icon-left" alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-toggle-on"/>
                                </HBox>
                                <MFXComboBox fx:id="cmbAreaEstado" promptText=" "
                                             styleClass="pixel-history-combo"
                                             StackPane.alignment="CENTER_LEFT"/>
                                <Label text="Estado" styleClass="floating-label" StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                        </VBox>

                        <!-- Mensajes de validación -->
                        <Label fx:id="lblMensajeArea" styleClass="form-mensaje" text=""
                               wrapText="true" managed="false" visible="false"/>
                    </VBox>

                    <!-- Footer formulario -->
                    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form-footer">
                        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                        <MFXButton fx:id="btnGuardarArea" maxWidth="Infinity"
                                   onAction="#guardarArea" styleClass="btn-raised-primary"
                                   text="Guardar Área">
                            <graphic><FontIcon iconLiteral="fas-save" iconSize="12"/></graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnNuevoAreaForm" maxWidth="Infinity"
                                   onAction="#prepararNuevoArea" styleClass="btn-outline-primary"
                                   text="Nueva Área">
                            <graphic><FontIcon iconLiteral="fas-plus" iconSize="12"/></graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnEliminarAreaForm" disable="true" maxWidth="Infinity"
                                   onAction="#eliminarArea" styleClass="btn-outline-danger"
                                   text="Eliminar">
                            <graphic><FontIcon iconLiteral="fas-trash-alt" iconSize="12"/></graphic>
                        </MFXButton>
                    </HBox>
                </VBox>
            </MFXScrollPane>
        </VBox>
    </HBox>
</StackPane>
