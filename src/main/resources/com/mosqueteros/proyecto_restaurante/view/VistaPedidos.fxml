<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import io.github.palexdev.materialfx.controls.MFXScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import io.github.palexdev.materialfx.controls.*?>

<StackPane
    styleClass="layout-root"
    stylesheets="@../styles/styles.css,@../styles/theme-overrides.css,@../styles/vista-mesas.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.mosqueteros.proyecto_restaurante.controller.PedidoController">

    <padding><Insets bottom="28" left="28" right="28" top="28" /></padding>

    <HBox
        alignment="TOP_LEFT"
        fillHeight="true"
        maxHeight="Infinity"
        maxWidth="Infinity"
        spacing="24">

        <!-- ═══════════════════════════════════════════════════════════════
             COLUMNA IZQUIERDA  —  Tablas de Pedidos y Detalles
        ════════════════════════════════════════════════════════════════ -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" maxHeight="Infinity">

            <!-- HEADER PRINCIPAL -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <FontIcon iconLiteral="fas-clipboard-list" iconSize="24" styleClass="header-icon" />
                <Label styleClass="panel-card__title" text="Pedidos y Comandas" />
            </HBox>

            <!-- CARD SUPERIOR: LISTA DE PEDIDOS -->
            <VBox styleClass="panel-card" VBox.vgrow="ALWAYS" maxHeight="Infinity" spacing="0">

                <!-- BARRA DE FILTROS PEDIDOS -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <padding><Insets top="16" right="20" bottom="16" left="20" /></padding>

                    <DatePicker fx:id="dpFechaPedido"
                                promptText="Fecha"
                                prefWidth="140"
                                styleClass="filtro-combo-nativo" />

                    <Region HBox.hgrow="ALWAYS" />

                    <MFXComboBox fx:id="cmbFiltroSedePedido"
                              promptText="Sede"
                              prefWidth="130"
                              styleClass="filtro-combo-nativo" />

                    <MFXComboBox fx:id="cmbFiltroMesaPedido"
                              promptText="Mesa"
                              prefWidth="130"
                              styleClass="filtro-combo-nativo" />

                    <MFXComboBox fx:id="cmbFiltroEstadoPedido"
                              promptText="Estado"
                              prefWidth="130"
                              styleClass="filtro-combo-nativo" />

                    <MFXButton fx:id="btnBuscarPedido"
                               onAction="#buscarPedidoMock"
                               styleClass="btn-buscar-raised,btn,btn--primary,btn--search"
                               text="Buscar">
                        <graphic><FontIcon iconLiteral="fas-search" iconSize="12" styleClass="icon-on-primary"/></graphic>
                    </MFXButton>

                    <MFXButton fx:id="btnLimpiarFiltroPedido"
                               onAction="#limpiarFiltrosPedidoMock"
                               styleClass="btn-limpiar-flat,btn,btn--ghost"
                               text="Limpiar">
                        <graphic><FontIcon iconLiteral="fas-sync" iconSize="12" styleClass="icon-muted"/></graphic>
                    </MFXButton>
                </HBox>

                <Region styleClass="divider" maxHeight="1" minHeight="1" />

                <!-- TABLA PEDIDOS -->
                <StackPane VBox.vgrow="ALWAYS">
                    <TableView fx:id="tblListaPedidos" styleClass="table,table--data" VBox.vgrow="ALWAYS">
                        <placeholder>
                            <VBox alignment="CENTER" spacing="10">
                                <FontIcon iconLiteral="fas-clipboard" iconSize="48" styleClass="icon-muted"/>
                                <Label text="No hay pedidos para los filtros seleccionados" styleClass="state-empty__subtitle"/>
                            </VBox>
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colPedId" prefWidth="60" text="ID" />
                            <TableColumn fx:id="colPedMesero" prefWidth="120" text="Mesero" />
                            <TableColumn fx:id="colPedMesa" prefWidth="80" text="Mesa" />
                            <TableColumn fx:id="colPedFecha" prefWidth="130" text="Fecha" />
                            <TableColumn fx:id="colPedObs" prefWidth="180" text="Observaciones" />
                            <TableColumn fx:id="colPedEstado" prefWidth="100" text="Estado" />
                        </columns>
                    </TableView>
                </StackPane>

                <Region styleClass="divider" maxHeight="1" minHeight="1" />

                <!-- FOOTER DE TABLA PEDIDOS -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="layout-footer">
                    <padding><Insets top="14" right="20" bottom="14" left="20" /></padding>
                    <Label fx:id="lblConteoPedidos" styleClass="conteo-label"
                           text="0 pedidos" HBox.hgrow="ALWAYS" />
                    <MFXButton fx:id="btnNuevoPedido" onAction="#prepararNuevoPedidoMock"
                               styleClass="btn-outline-primary,btn,btn--outline-primary" text="Nuevo Pedido">
                        <graphic><FontIcon iconLiteral="fas-plus" iconSize="11" styleClass="icon-primary"/></graphic>
                    </MFXButton>
                    <MFXButton fx:id="btnCambiarEstadoPedido" onAction="#cambiarEstadoPedidoMock"
                               styleClass="btn-outline-secondary,btn,btn--outline-secondary" text="Cambiar Estado">
                        <graphic><FontIcon iconLiteral="fas-exchange-alt" iconSize="11" styleClass="icon-primary"/></graphic>
                    </MFXButton>
                    <MFXButton fx:id="btnCancelarPedido" onAction="#cancelarPedidoMock"
                               styleClass="btn-outline-danger,btn,btn--outline-danger" text="Cancelar Pedido">
                        <graphic><FontIcon iconLiteral="fas-times" iconSize="11" styleClass="icon-danger"/></graphic>
                    </MFXButton>
                </HBox>
            </VBox>

            <!-- CARD INFERIOR: DETALLE DEL PEDIDO -->
            <VBox styleClass="panel-card" VBox.vgrow="NEVER" maxHeight="300" spacing="0">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <padding><Insets top="14" right="20" bottom="14" left="20" /></padding>
                    <FontIcon iconLiteral="fas-list-ul" iconSize="16" styleClass="icon-muted" />
                    <Label styleClass="panel-card__subtitle" text="Detalle del pedido" HBox.hgrow="ALWAYS"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <MFXButton fx:id="btnAgregarDetalle" onAction="#agregarDetalleMock"
                               styleClass="btn-outline-primary,btn,btn--outline-primary" text="Agregar Plato">
                        <graphic><FontIcon iconLiteral="fas-plus" iconSize="11" styleClass="icon-primary"/></graphic>
                    </MFXButton>
                    <MFXButton fx:id="btnQuitarDetalle" onAction="#quitarDetalleMock"
                               styleClass="btn-outline-danger,btn,btn--outline-danger" text="Quitar Plato">
                        <graphic><FontIcon iconLiteral="fas-minus" iconSize="11" styleClass="icon-danger"/></graphic>
                    </MFXButton>
                </HBox>

                <Region styleClass="divider" maxHeight="1" minHeight="1" />

                <!-- TABLA DETALLE -->
                <TableView fx:id="tblDetallePedido" styleClass="table,table--data" prefHeight="160">
                    <placeholder>
                            <Label text="Selecciona un pedido para ver su detalle" styleClass="state-empty__subtitle"/>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colDtPlato" prefWidth="180" text="Plato" />
                        <TableColumn fx:id="colDtCantidad" prefWidth="80" text="Cantidad" />
                        <TableColumn fx:id="colDtPrecio" prefWidth="100" text="Precio" />
                        <TableColumn fx:id="colDtObs" prefWidth="180" text="Observación" />
                        <TableColumn fx:id="colDtEstado" prefWidth="100" text="Estado" />
                    </columns>
                </TableView>

                <Region styleClass="divider" maxHeight="1" minHeight="1" />

                <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="layout-footer">
                    <padding><Insets top="14" right="20" bottom="14" left="20" /></padding>
                    <Label styleClass="form-label,form-label-strong" text="Total del pedido:" />
                    <Label fx:id="lblTotalPedido" styleClass="total-pedido-label" text="COP 0.00" />
                </HBox>
            </VBox>
        </VBox>

        <!-- ═══════════════════════════════════════════════════════════════
             COLUMNA DERECHA  —  Formulario Cocina/Comandas
        ════════════════════════════════════════════════════════════════ -->
        <MFXScrollPane
            fitToWidth="true"
            fitToHeight="false"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="form__body"
            HBox.hgrow="NEVER"
            minWidth="340"
            maxWidth="360">

            <VBox spacing="0" styleClass="panel-card" minWidth="338">
                <!-- Header del form -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <padding><Insets top="20" right="24" bottom="20" left="24" /></padding>
                    <StackPane styleClass="form-header-badge">
                        <FontIcon iconLiteral="fas-fire" iconSize="15"
                                  styleClass="form-header-badge-icon" />
                    </StackPane>
                    <Label styleClass="form-header-titulo" text="Cocina / Comandas" />
                </HBox>

                <Region styleClass="divider" maxHeight="1" minHeight="1" />

                <!-- Sección Comandas en vivo -->
                <VBox spacing="10">
                    <padding><Insets top="16" right="22" bottom="16" left="22" /></padding>
                    <Label styleClass="form__label" text="Platos en preparación" />
                    <TableView fx:id="tblComandas" styleClass="table,table--data" prefHeight="200">
                        <placeholder>
                            <Label text="Sin comandas pendientes" styleClass="state-empty__subtitle"/>
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colComMesa" prefWidth="60" text="Mesa" />
                            <TableColumn fx:id="colComPlato" prefWidth="130" text="Plato" />
                            <TableColumn fx:id="colComCant" prefWidth="70" text="Cant." />
                        </columns>
                    </TableView>
                    
                    <Region prefHeight="8" />
                    
                    <Label styleClass="form__label,section-title-strong" text="Actualizar estado de comanda" />
                    
                    <VBox spacing="5">
                        <HBox alignment="CENTER_LEFT" spacing="10" prefHeight="44" styleClass="form__control-wrap">
                            <FontIcon iconLiteral="fas-tasks" iconSize="14" styleClass="icon-muted" />
                            <MFXComboBox fx:id="cmbEstadoDetalle" promptText="Nuevo estado..."
                                styleClass="input-combo" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        </HBox>
                    </VBox>
                    <MFXButton fx:id="btnMarcarEstadoDetalle" maxWidth="Infinity"
                               onAction="#marcarEstadoDetalleMock" styleClass="btn-outline-primary-form,btn,btn--outline-primary" text="Actualizar estado">
                        <graphic><FontIcon iconLiteral="fas-check-circle" iconSize="13" styleClass="icon-primary"/></graphic>
                    </MFXButton>
                </VBox>

                <Region styleClass="divider" maxHeight="1" minHeight="1" />

                <!-- Sección Agregar Plato Manual -->
                <VBox spacing="16">
                    <padding><Insets top="20" right="22" bottom="22" left="22" /></padding>
                    <Label styleClass="form__label,section-title-strong" text="Agregar al Pedido Manualmente" />

                    <!-- Menú/Plato -->
                    <VBox spacing="5">
                        <Label styleClass="form__label" text="Plato" />
                        <HBox alignment="CENTER_LEFT" spacing="10" prefHeight="44" styleClass="form__control-wrap">
                            <FontIcon iconLiteral="fas-utensils" iconSize="14" styleClass="icon-muted" />
                            <MFXComboBox fx:id="cmbPlatoDetalle" promptText="Seleccionar plato..."
                                styleClass="input-combo" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        </HBox>
                    </VBox>

                    <!-- Cantidad -->
                    <VBox spacing="5">
                        <Label styleClass="form__label" text="Cantidad" />
                        <HBox alignment="CENTER_LEFT" spacing="10" prefHeight="44" styleClass="form__control-wrap">
                            <FontIcon iconLiteral="fas-hashtag" iconSize="14" styleClass="icon-muted" />
                            <MFXTextField fx:id="txtCantidadDetalle" promptText="1"
                                styleClass="input" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <!-- Observación -->
                    <VBox spacing="5">
                        <Label styleClass="form__label" text="Observación" />
                        <HBox alignment="TOP_LEFT" spacing="10" styleClass="form__control-wrap">
                            <padding><Insets top="12" right="6" bottom="12" left="10" /></padding>
                            <FontIcon iconLiteral="fas-comment-alt" iconSize="14" styleClass="icon-muted" />
                            <TextArea fx:id="txtObservacionDetalle" promptText="Ej: Sin cebolla..."
                                      prefRowCount="2" wrapText="true"
                                      styleClass="detalle-observacion-area"
                                      HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <Label fx:id="lblMensajePedido" styleClass="form__status"
                           text="" wrapText="true" managed="false" visible="false"/>
                </VBox>

                <Region styleClass="divider" maxHeight="1" minHeight="1" />

                <!-- Footer Formulario -->
                <VBox spacing="10" styleClass="form__actions">
                    <padding><Insets top="18" right="22" bottom="22" left="22" /></padding>
                    <MFXButton fx:id="btnConfirmarAgregarDetalle" maxWidth="Infinity"
                               onAction="#confirmarAgregarDetalleMock" styleClass="btn-raised-primary,btn,btn--primary" text="Agregar Plato al Pedido">
                        <graphic><FontIcon iconLiteral="fas-cart-plus" iconSize="13" styleClass="icon-on-primary"/></graphic>
                    </MFXButton>
                </VBox>

            </VBox>
        </MFXScrollPane>
    </HBox>
</StackPane>
