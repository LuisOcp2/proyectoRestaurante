<?xml version="1.0" encoding="UTF-8"?>
<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXPasswordField?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
╔════════════════════════════════════════════════════════════════════════════╗
║  VistaUsuarios.fxml  —  CRUD Usuarios del Sistema                       ║
║                                                                          ║
║  Estructura basada en el diseño system "The Modern Maître D'"            ║
║  Campos mapeados a tabla: usuario (BD restaurante_2026)                 ║
║                                                                          ║
║  CONTRATO CONTROLADOR (UsuarioController):                              ║
║    txtBuscarUsuario    → MFXTextField  búsqueda por nombre/login        ║
║    cmbFiltroPerfil     → ComboBox<String> filtro por perfil             ║
║    cmbFiltroEstado     → ComboBox<String> filtro por estado             ║
║    tblListaUsuarios    → MFXTableView<Usuario>                          ║
║    lblConteoUsuarios   → Label conteo de resultados                     ║
║    txtUsuNombre        → MFXTextField  usunombre                        ║
║    txtUsuApellido      → MFXTextField  usuapellido                      ║
║    txtUsuLogin         → MFXTextField  usulogin                         ║
║    txtUsuCorreo        → MFXTextField  usucorreo                        ║
║    txtUsuTelefono      → MFXTextField  usutelefono                      ║
║    txtUsuDireccion     → MFXTextField  usudireccion                     ║
║    txtUsuPass          → MFXPasswordField usupass                       ║
║    cmbUsuPerfil        → MFXComboBox<String> perfil FK                  ║
║    cmbUsuEstado        → MFXComboBox<String> usuestado                  ║
║    lblMensajeUsuario   → Label mensajes de validación/resultado         ║
╚════════════════════════════════════════════════════════════════════════════╝
-->
<StackPane
    styleClass="root-container"
    stylesheets="@../styles/styles.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.mosqueteros.proyecto_restaurante.controller.UsuarioController">

    <!-- Padding exterior: 32px en todos los lados -->
    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

    <HBox
        alignment="TOP_LEFT"
        fillHeight="true"
        maxHeight="Infinity"
        maxWidth="Infinity"
        spacing="24">

        <!-- COLUMNA IZQUIERDA  —  Título + Card con tabla -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" maxHeight="Infinity">

            <!-- Encabezado de sección con overline y título -->
            <VBox alignment="CENTER_LEFT" spacing="4">
                <!-- Label USUARIOS overline arriba del título: 12px Bold #7E3BED -->
                <Label text="USUARIOS" styleClass="input-label"/>
                <!-- Título de sección: 32px Bold #000000 -->
                <Label styleClass="titulo-texto" text="Usuarios"/>
            </VBox>

            <!-- Card principal: VBox styleClass="main-card" (bg #FFFFFF, radius 12, ambient shadow) -->
            <VBox styleClass="main-card" VBox.vgrow="ALWAYS" maxHeight="Infinity" spacing="0">

                <!-- Barra filtros: background #F2F0F7 (cambio tonal), padding 16 24, SIN border -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="filter-bar">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                    <!-- Campo de búsqueda por nombre o login -->
                    <HBox styleClass="search-wrapper" HBox.hgrow="ALWAYS" minWidth="200">
                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="icon-muted"/>
                        <MFXTextField
                            fx:id="txtBuscarUsuario"
                            promptText="Buscar por nombre o login..."
                            styleClass="search-field"
                            HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Filtro por perfil/rol del usuario -->
                    <VBox spacing="2">
                        <Label text="Perfil" styleClass="input-label"/>
                        <ComboBox fx:id="cmbFiltroPerfil"
                                  promptText="Todos los perfiles"
                                  prefWidth="140"
                                  styleClass="filtro-combo-nativo"/>
                    </VBox>

                    <!-- Filtro por estado Activo / Inactivo -->
                    <VBox spacing="2">
                        <Label text="Estado" styleClass="input-label"/>
                        <ComboBox fx:id="cmbFiltroEstado"
                                  promptText="Todos los estados"
                                  prefWidth="120"
                                  styleClass="filtro-combo-nativo"/>
                    </VBox>

                    <!-- Botón para ejecutar la búsqueda -->
                    <MFXButton fx:id="btnBuscarUsuario"
                               onAction="#buscarUsuario"
                               styleClass="btn-outline-primary"
                               text="Buscar">
                        <graphic><FontIcon iconLiteral="fas-search" iconSize="12"/></graphic>
                    </MFXButton>

                    <!-- Botón para limpiar los filtros -->
                    <MFXButton fx:id="btnLimpiarFiltroUsuario"
                               onAction="#limpiarFiltros"
                               styleClass="btn-outline-secondary"
                               text="Limpiar">
                        <graphic><FontIcon iconLiteral="fas-sync" iconSize="12"/></graphic>
                    </MFXButton>
                </HBox>

                <!-- Cabecera de columnas de la tabla -->
                <HBox styleClass="table-header-row">
                    <Label text="ID" styleClass="col-header" prefWidth="60"/>
                    <Label text="Nombre" styleClass="col-header" HBox.hgrow="ALWAYS"/>
                    <Label text="Apellido" styleClass="col-header" HBox.hgrow="ALWAYS"/>
                    <Label text="Login" styleClass="col-header" prefWidth="100"/>
                    <Label text="Correo" styleClass="col-header" HBox.hgrow="ALWAYS"/>
                    <Label text="Perfil" styleClass="col-header" prefWidth="100"/>
                    <Label text="Estado" styleClass="col-header" prefWidth="80"/>
                </HBox>

                <!-- Área de tabla con estado vacío -->
                <VBox VBox.vgrow="ALWAYS" spacing="0">
                    <!-- Tabla de usuarios (TableView poblada desde el controlador) -->
                    <TableView
                        fx:id="tblListaUsuarios"
                        styleClass="mesas-table">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <!-- ID -->
                            <TableColumn fx:id="colIdUsuario" prefWidth="50" text="ID" />
                            <!-- Nombre -->
                            <TableColumn fx:id="colNombre" prefWidth="120" text="NOMBRE" />
                            <!-- Apellido -->
                            <TableColumn fx:id="colApellido" prefWidth="120" text="APELLIDO" />
                            <!-- Login -->
                            <TableColumn fx:id="colLogin" prefWidth="100" text="LOGIN" />
                            <!-- Correo -->
                            <TableColumn fx:id="colCorreo" prefWidth="150" text="CORREO" />
                            <!-- Perfil -->
                            <TableColumn fx:id="colPerfil" prefWidth="100" text="PERFIL" />
                            <!-- Estado -->
                            <TableColumn fx:id="colEstado" prefWidth="80" text="ESTADO" />
                        </columns>
                    </TableView>

                    <!-- Estado vacío: imagen + textos informativos -->
                    <VBox fx:id="boxPlaceholder"
                          alignment="CENTER"
                          spacing="16"
                          visible="true"
                          managed="true"
                          styleClass="empty-state">
                        <FontIcon iconLiteral="fas-user-slash" iconSize="48" styleClass="icon-muted"/>
                        <Label text="No hay usuarios registrados" styleClass="titulo-texto"/>
                        <Label text="Ajusta los filtros o agrega un nuevo usuario." styleClass="conteo-label"/>
                    </VBox>
                </VBox>

                <!-- Footer de la tabla: background #F2F0F7, SIN border superior -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="table-footer">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                    <!-- Etiqueta con total de usuarios encontrados -->
                    <Label fx:id="lblConteoUsuarios"
                           styleClass="conteo-label"
                           text="0 usuarios encontrados"
                           HBox.hgrow="ALWAYS"/>

                    <!-- Botón para preparar formulario de nuevo usuario -->
                    <MFXButton fx:id="btnNuevoUsuario"
                               onAction="#prepararNuevoUsuario"
                               styleClass="btn-raised-primary"
                               text="Nuevo Usuario">
                        <graphic><FontIcon iconLiteral="fas-plus" iconSize="12"/></graphic>
                    </MFXButton>
                </HBox>
            </VBox>
        </VBox>

        <!-- COLUMNA DERECHA  —  Formulario de detalle / edición -->
        <VBox prefWidth="360" maxWidth="360" minWidth="320" spacing="0">

            <!-- Encabezado del formulario: badge violeta + título -->
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="form-header">
                <padding><Insets top="20" right="24" bottom="20" left="24" /></padding>
                <StackPane styleClass="form-header-badge">
                    <FontIcon iconLiteral="fas-user-cog" iconSize="18"/>
                </StackPane>
                <Label styleClass="form-header-titulo" text="Detalle de Usuario"/>
            </HBox>

            <!-- Formulario derecho: ScrollPane con VBox styleClass="main-card" -->
            <ScrollPane fitToWidth="true" 
                        fitToHeight="false" 
                        hbarPolicy="NEVER" 
                        vbarPolicy="AS_NEEDED"
                        styleClass="form-scroll">
                <VBox styleClass="main-card" spacing="0">

                    <!-- Campos del formulario -->
                    <VBox spacing="18">
                        <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>

                        <!-- Campo: Nombre (usunombre) -->
                        <VBox spacing="6">
                            <Label text="Nombre" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-user" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtUsuNombre"
                                              promptText="Ej. Luis"
                                              styleClass="input-field"
                                              HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Apellido (usuapellido) -->
                        <VBox spacing="6">
                            <Label text="Apellido" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-user" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtUsuApellido"
                                              promptText="Ej. Ocampo"
                                              styleClass="input-field"
                                              HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Login (usulogin) - único en BD -->
                        <VBox spacing="6">
                            <Label text="Login" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-id-badge" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtUsuLogin"
                                              promptText="Ej. luis.ocampo"
                                              styleClass="input-field"
                                              HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Correo (usucorreo) - único en BD -->
                        <VBox spacing="6">
                            <Label text="Correo electrónico" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-envelope" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtUsuCorreo"
                                              promptText="correo@email.com"
                                              styleClass="input-field"
                                              HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Teléfono (usutelefono) -->
                        <VBox spacing="6">
                            <Label text="Teléfono" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-phone" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtUsuTelefono"
                                              promptText="Ej. 3001234567"
                                              styleClass="input-field"
                                              HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Dirección (usudireccion) -->
                        <VBox spacing="6">
                            <Label text="Dirección" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-map-marker-alt" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtUsuDireccion"
                                              promptText="Ej. Calle 37N #2Bn-93"
                                              styleClass="input-field"
                                              HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Contraseña (usupass) - solo se muestra al crear/cambiar -->
                        <VBox spacing="6">
                            <Label text="Contraseña" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-lock" iconSize="14" styleClass="icon-muted"/>
                                <MFXPasswordField fx:id="txtUsuPass"
                                                  promptText="Min. 6 caracteres"
                                                  styleClass="input-field"
                                                  HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Perfil/Rol (perfid FK → perfil) -->
                        <VBox spacing="6">
                            <Label text="Perfil / Rol" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-user-shield" iconSize="14" styleClass="icon-muted"/>
                                <MFXComboBox fx:id="cmbUsuPerfil"
                                             promptText="Seleccionar perfil"
                                             styleClass="input-combo"
                                             HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Estado (usuestado: Activo/Inactivo) -->
                        <VBox spacing="6">
                            <Label text="Estado" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-toggle-on" iconSize="14" styleClass="icon-muted"/>
                                <MFXComboBox fx:id="cmbUsuEstado"
                                             promptText="Seleccionar estado"
                                             styleClass="input-combo"
                                             HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Etiqueta de mensajes de validación o confirmación -->
                        <Label fx:id="lblMensajeUsuario"
                               styleClass="form-mensaje"
                               text=""
                               wrapText="true"
                               managed="false"
                               visible="false"/>
                    </VBox>

                    <!-- Footer del formulario: background #F2F0F7, SIN border superior -->
                    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form-footer">
                        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                        <!-- Botón Guardar Usuario -->
                        <MFXButton fx:id="btnGuardarUsuario"
                                   maxWidth="Infinity"
                                   onAction="#guardarUsuario"
                                   styleClass="btn-raised-primary"
                                   text="Guardar Usuario">
                            <graphic><FontIcon iconLiteral="fas-save" iconSize="12"/></graphic>
                        </MFXButton>

                        <!-- Botón Nuevo Usuario -->
                        <MFXButton fx:id="btnNuevoUsuarioForm"
                                   maxWidth="Infinity"
                                   onAction="#prepararNuevoUsuario"
                                   styleClass="btn-outline-primary"
                                   text="Nuevo Usuario">
                            <graphic><FontIcon iconLiteral="fas-plus" iconSize="12"/></graphic>
                        </MFXButton>

                        <!-- Botón Eliminar Usuario -->
                        <MFXButton fx:id="btnEliminarUsuarioForm"
                                   disable="true"
                                   maxWidth="Infinity"
                                   onAction="#eliminarUsuario"
                                   styleClass="btn-outline-danger"
                                   text="Eliminar">
                            <graphic><FontIcon iconLiteral="fas-trash-alt" iconSize="12"/></graphic>
                        </MFXButton>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</StackPane>