<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import io.github.palexdev.materialfx.controls.*?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
            
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="custom-header">
                    <padding>
                        <Insets left="40.0" right="40.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label styleClass="logo-icon" text="" /> 
                                <Label styleClass="logo-text" text="Restaurante Deluxe" />
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="25.0">
                            <children>
                                <MFXButton styleClass="nav-button" text="Facturación" />
                                <MFXButton styleClass="nav-button-active" text="Clientes" />
                                <MFXButton styleClass="nav-button" text="Inventario" />
                                <MFXButton styleClass="nav-button" text="Reportes" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <VBox spacing="5.0">
                    <padding>
                        <Insets left="40.0" right="40.0" />
                    </padding>
                    <children>
                        <Label styleClass="page-title" text="Gestión de Clientes" />
                        <Label styleClass="page-subtitle" text="Administre la base de datos de sus comensales y gestione su fidelización." />
                    </children>
                </VBox>

                <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="40.0" right="40.0" />
                    </padding>
                    <children>
                  
                        <VBox maxWidth="400.0" minWidth="380.0" spacing="20.0" styleClass="client-form-card">
                            <children>
                                <Label styleClass="card-header-title" text="Registrar Cliente" />
                        
                                <GridPane hgap="15.0" vgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="input-label" text="TIPO DOC." />
                                                <MFXComboBox fx:id="comboDoc" maxWidth="1.7976931348623157E308" styleClass="custom-input" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" GridPane.columnIndex="1">
                                            <children>
                                                <Label styleClass="input-label" text="NÚMERO" />
                                                <MFXTextField fx:id="txtNumero" maxWidth="1.7976931348623157E308" promptText="12345678" styleClass="custom-input" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                                            <children>
                                                <Label styleClass="input-label" text="NOMBRES" />
                                                <MFXTextField fx:id="txtNombres" maxWidth="1.7976931348623157E308" promptText="Juan Alberto" styleClass="custom-input" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="2">
                                            <children>
                                                <Label styleClass="input-label" text="APELLIDOS" />
                                                <MFXTextField fx:id="txtApellidos" maxWidth="1.7976931348623157E308" promptText="Pérez López" styleClass="custom-input" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="3">
                                            <children>
                                                <Label styleClass="input-label" text="CORREO" />
                                                <MFXTextField fx:id="txtEmail" maxWidth="1.7976931348623157E308" promptText="cliente@ejemplo.com" styleClass="custom-input" />
                                            </children>
                                        </VBox>
                                    </children>
                                </GridPane>
                        
                                <Region VBox.vgrow="ALWAYS" />
                        
                                <HBox spacing="15.0">
                                    <children>
                                        <MFXButton fx:id="btnCancelar" maxWidth="1.7976931348623157E308" prefHeight="45.0" styleClass="btn-cancel" text="Cancelar" HBox.hgrow="ALWAYS" />
                                        <MFXButton fx:id="btnGuardar" maxWidth="1.7976931348623157E308" prefHeight="45.0" styleClass="btn-save" text="Guardar" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="search-container">
                                    <children>
                                        <MFXTextField fx:id="txtBuscar"  prefHeight="45.0" promptText="Buscar por nombre, documento o correo..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                                        <MFXButton prefHeight="45.0" styleClass="btn-outline" text="Filtros" />
                                        <MFXButton contentDisplay="GRAPHIC_ONLY" prefHeight="45.0" prefWidth="45.0" styleClass="btn-outline" text="R" />
                                    </children>
                                </HBox>
      
                                <TableView fx:id="tablaClientes" styleClass="custom-table" VBox.vgrow="ALWAYS" />
      
                            </children>
                        </VBox>
                 

                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
   <stylesheets>
      <URL value="@../styles/clientes.css" />
      <URL value="@../styles/clientes.css" />
   </stylesheets>
</AnchorPane>
