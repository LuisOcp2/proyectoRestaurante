<?xml version="1.0" encoding="UTF-8"?>
<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  VistaCategoriaInsumo.fxml — CRUD Categorías de Insumo

  CAMBIO: Se reemplazó MFXTableView (incompatible con PropertyValueFactory/cellValueFactory en FXML)
  por TableView estándar de JavaFX. Las columnas usan PropertyValueFactory que enlaza con
  los JavaFX Properties del modelo CategoriaInsumo.

  CONTRATO CONTROLADOR (CategoriaInsumoController):
    txtBuscarCategoria  → MFXTextField  búsqueda por nombre/descripción
    cmbFiltroEstado     → ComboBox<String> filtro de estado
    tblListaCategorias  → TableView<CategoriaInsumo>
    colId               → TableColumn ID
    colNombre           → TableColumn Nombre
    colDescripcion      → TableColumn Descripción
    colEstado           → TableColumn Estado
    lblConteoCategorias → Label conteo de resultados
    boxPlaceholder      → VBox estado vacío
    txtCatNombre        → MFXTextField nombre
    txtCatDescripcion   → MFXTextField descripción
    cmbCatEstado        → ComboBox<String> estado
    lblMensajeCategoria → Label mensajes de validación
-->
<StackPane
    styleClass="root-container"
    stylesheets="@../styles/styles.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.mosqueteros.proyecto_restaurante.controller.CategoriaInsumoController">

    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

    <HBox alignment="TOP_LEFT" fillHeight="true"
          maxHeight="Infinity" maxWidth="Infinity" spacing="24">

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA IZQUIERDA: Título + Card con tabla                      -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" maxHeight="Infinity">

            <!-- Encabezado de sección -->
            <VBox alignment="CENTER_LEFT" spacing="4">
                <Label text="CATEGORÍAS DE INSUMO" styleClass="input-label"/>
                <Label styleClass="titulo-texto" text="Categorías de Insumo"/>
            </VBox>

            <!-- Card principal -->
            <VBox styleClass="main-card" VBox.vgrow="ALWAYS" maxHeight="Infinity" spacing="0">

                <!-- Barra de filtros -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="filter-bar">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                    <!-- Campo de búsqueda libre -->
                    <HBox styleClass="search-wrapper" HBox.hgrow="ALWAYS" minWidth="200">
                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="icon-muted"/>
                        <MFXTextField
                            fx:id="txtBuscarCategoria"
                            promptText="Buscar por nombre o descripción..."
                            styleClass="search-field"
                            HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Filtro por estado (ComboBox nativo JavaFX) -->
                    <VBox spacing="2">
                        <Label text="Estado" styleClass="input-label"/>
                        <ComboBox fx:id="cmbFiltroEstado"
                                  promptText="Todos los estados"
                                  prefWidth="140"
                                  styleClass="filtro-combo-nativo"/>
                    </VBox>

                    <!-- Botón Buscar -->
                    <Button fx:id="btnBuscarCategoria"
                            onAction="#buscarCategoria"
                            styleClass="btn-outline-primary"
                            text="Buscar"/>

                    <!-- Botón Limpiar filtros -->
                    <Button fx:id="btnLimpiarFiltroCategoria"
                            onAction="#limpiarFiltros"
                            styleClass="btn-outline-secondary"
                            text="Limpiar"/>
                </HBox>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- TABLA ESTÁNDAR JavaFX (PropertyValueFactory compatible) -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <VBox VBox.vgrow="ALWAYS" spacing="0">
                    <TableView fx:id="tblListaCategorias"
                               styleClass="mesas-table"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <!-- Columna ID -->
                            <TableColumn fx:id="colId" text="ID" prefWidth="60">
                                <cellValueFactory>
                                    <PropertyValueFactory property="idCategoriaInsumo"/>
                                </cellValueFactory>
                            </TableColumn>

                            <!-- Columna Nombre -->
                            <TableColumn fx:id="colNombre" text="NOMBRE">
                                <cellValueFactory>
                                    <PropertyValueFactory property="nombre"/>
                                </cellValueFactory>
                            </TableColumn>

                            <!-- Columna Descripción -->
                            <TableColumn fx:id="colDescripcion" text="DESCRIPCIÓN">
                                <cellValueFactory>
                                    <PropertyValueFactory property="descripcion"/>
                                </cellValueFactory>
                            </TableColumn>

                            <!-- Columna Estado -->
                            <TableColumn fx:id="colEstado" text="ESTADO" prefWidth="90">
                                <cellValueFactory>
                                    <PropertyValueFactory property="estado"/>
                                </cellValueFactory>
                            </TableColumn>
                        </columns>
                    </TableView>

                    <!-- Estado vacío cuando no hay datos -->
                    <VBox fx:id="boxPlaceholder"
                          alignment="CENTER"
                          spacing="16"
                          visible="true"
                          managed="true"
                          styleClass="empty-state">
                        <FontIcon iconLiteral="fas-folder-open" iconSize="48" styleClass="icon-muted"/>
                        <Label text="No hay categorías de insumo registradas" styleClass="titulo-texto"/>
                        <Label text="Ajusta los filtros o agrega una nueva categoría." styleClass="conteo-label"/>
                    </VBox>
                </VBox>

                <!-- Footer de tabla -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="table-footer">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>
                    <Label fx:id="lblConteoCategorias"
                           styleClass="conteo-label"
                           text="0 categorías encontradas"
                           HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnNuevoCategoria"
                            onAction="#prepararNuevoCategoria"
                            styleClass="btn-raised-primary"
                            text="Nueva Categoría"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMNA DERECHA: Formulario de detalle / edición               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <VBox prefWidth="360" maxWidth="360" minWidth="320" spacing="0">

            <!-- Encabezado del formulario -->
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="form-header">
                <padding><Insets top="20" right="24" bottom="20" left="24" /></padding>
                <StackPane styleClass="form-header-badge">
                    <FontIcon iconLiteral="fas-folder-open" iconSize="18"/>
                </StackPane>
                <Label styleClass="form-header-titulo" text="Detalle de Categoría"/>
            </HBox>

            <!-- Formulario con ScrollPane -->
            <javafx.scene.control.ScrollPane
                fitToWidth="true"
                fitToHeight="false"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                styleClass="form-scroll">
                <VBox styleClass="main-card" spacing="0">

                    <VBox spacing="18">
                        <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>

                        <!-- Campo: Nombre -->
                        <VBox spacing="6">
                            <Label text="Nombre *" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-tag" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtCatNombre"
                                              promptText="Ej. Lácteos"
                                              styleClass="input-field"
                                              HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Descripción -->
                        <VBox spacing="6">
                            <Label text="Descripción" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-sticky-note" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtCatDescripcion"
                                              promptText="Descripción detallada"
                                              styleClass="input-field"
                                              HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Estado -->
                        <VBox spacing="6">
                            <Label text="Estado" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-toggle-on" iconSize="14" styleClass="icon-muted"/>
                                <ComboBox fx:id="cmbCatEstado"
                                          promptText="Seleccionar estado"
                                          styleClass="input-combo"
                                          HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Mensaje de validación / confirmación -->
                        <Label fx:id="lblMensajeCategoria"
                               styleClass="form-mensaje"
                               text=""
                               wrapText="true"
                               managed="false"
                               visible="false"/>
                    </VBox>

                    <!-- Footer del formulario -->
                    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form-footer">
                        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                        <Button fx:id="btnGuardarCategoria"
                                maxWidth="Infinity"
                                onAction="#guardarCategoria"
                                styleClass="btn-raised-primary"
                                text="Guardar Categoría"/>

                        <Button fx:id="btnNuevoCategoriaForm"
                                maxWidth="Infinity"
                                onAction="#prepararNuevoCategoria"
                                styleClass="btn-outline-primary"
                                text="Nueva Categoría"/>

                        <Button fx:id="btnEliminarCategoriaForm"
                                disable="true"
                                maxWidth="Infinity"
                                onAction="#eliminarCategoria"
                                styleClass="btn-outline-danger"
                                text="Eliminar"/>
                    </HBox>
                </VBox>
            </javafx.scene.control.ScrollPane>
        </VBox>
    </HBox>
</StackPane>
