<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import javafx.scene.control.Label?>
<?import io.github.palexdev.materialfx.controls.MFXScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import io.github.palexdev.materialfx.controls.*?>

<!--
  VistaCategoriaInsumo.fxml — CRUD Categorías de Insumo

  IMPORTANTE — JavaFX 21 + JPMS:
    PropertyValueFactory en FXML falla con "not a valid type" en proyectos modulares.
    Solución: las columnas se declaran solo con fx:id aquí;
    el binding (setCellValueFactory con lambda) se hace 100% en Java
    dentro de CategoriaInsumoController.configurarColumnas().

  CONTRATO CONTROLADOR (CategoriaInsumoController):
    txtBuscarCategoria  → MFXTextField
    cmbFiltroEstado     → MFXComboBox<String>
    tblListaCategorias  → TableView<CategoriaInsumo>
    colId               → TableColumn
    colNombre           → TableColumn
    colDescripcion      → TableColumn
    colEstado           → TableColumn
    lblConteoCategorias → Label
    boxPlaceholder      → VBox
    txtCatNombre        → MFXTextField
    txtCatDescripcion   → MFXTextField
    cmbCatEstado        → MFXComboBox<String>
    lblMensajeCategoria → Label
-->
<StackPane
    styleClass="root-container"
    stylesheets="@../styles/styles.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.mosqueteros.proyecto_restaurante.controller.CategoriaInsumoController">

    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

    <HBox alignment="TOP_LEFT" fillHeight="true"
          maxHeight="Infinity" maxWidth="Infinity" spacing="24">

        <!-- COLUMNA IZQUIERDA: Título + Card con tabla -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" maxHeight="Infinity">

            <!-- Encabezado de sección -->
            <VBox alignment="CENTER_LEFT" spacing="4">
                <Label text="CATEGORÍAS DE INSUMO" styleClass="input-label"/>
                <Label styleClass="titulo-texto" text="Categorías de Insumo"/>
            </VBox>

            <!-- Card principal -->
            <VBox styleClass="main-card" VBox.vgrow="ALWAYS" maxHeight="Infinity" spacing="0">

                <!-- Barra de filtros -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="filter-bar">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                    <!-- Campo de búsqueda libre -->
                    <HBox styleClass="search-wrapper" HBox.hgrow="ALWAYS" minWidth="200">
                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="icon-muted"/>
                        <MFXTextField
                            fx:id="txtBuscarCategoria"
                            promptText="Buscar por nombre o descripción..."
                            styleClass="search-field"
                            HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Filtro por estado -->
                    <VBox spacing="2">
                        <Label text="Estado" styleClass="input-label"/>
                        <MFXComboBox fx:id="cmbFiltroEstado"
                                  promptText="Todos los estados"
                                  prefWidth="140"
                                  styleClass="filtro-combo-nativo"/>
                    </VBox>

                    <MFXButton fx:id="btnBuscarCategoria"
                            onAction="#buscarCategoria"
                            styleClass="btn-outline-primary"
                            text="Buscar"/>

                    <MFXButton fx:id="btnLimpiarFiltroCategoria"
                            onAction="#limpiarFiltros"
                            styleClass="btn-outline-secondary"
                            text="Limpiar"/>
                </HBox>

                <!-- TABLA: columnas solo con fx:id, el binding se hace en Java -->
                <VBox VBox.vgrow="ALWAYS" spacing="0">
                    <TableView fx:id="tblListaCategorias"
                               styleClass="mesas-table"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId"          text="ID"          prefWidth="60"/>
                            <TableColumn fx:id="colNombre"      text="NOMBRE"/>
                            <TableColumn fx:id="colDescripcion" text="DESCRIPCIÓN"/>
                            <TableColumn fx:id="colEstado"      text="ESTADO"       prefWidth="90"/>
                        </columns>
                    </TableView>

                    <!-- Estado vacío cuando no hay registros -->
                    <VBox fx:id="boxPlaceholder"
                          alignment="CENTER"
                          spacing="16"
                          visible="true"
                          managed="true"
                          styleClass="empty-state">
                        <FontIcon iconLiteral="fas-folder-open" iconSize="48" styleClass="icon-muted"/>
                        <Label text="No hay categorías de insumo registradas" styleClass="titulo-texto"/>
                        <Label text="Ajusta los filtros o agrega una nueva categoría." styleClass="conteo-label"/>
                    </VBox>
                </VBox>

                <!-- Footer de tabla -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="table-footer">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>
                    <Label fx:id="lblConteoCategorias"
                           styleClass="conteo-label"
                           text="0 categorías encontradas"
                           HBox.hgrow="ALWAYS"/>
                    <MFXButton fx:id="btnNuevoCategoria"
                            onAction="#prepararNuevoCategoria"
                            styleClass="btn-raised-primary"
                            text="Nueva Categoría"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- COLUMNA DERECHA: Formulario de detalle / edición -->
        <VBox prefWidth="360" maxWidth="360" minWidth="320" spacing="0">

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="form-header">
                <padding><Insets top="20" right="24" bottom="20" left="24" /></padding>
                <StackPane styleClass="form-header-badge">
                    <FontIcon iconLiteral="fas-folder-open" iconSize="18"/>
                </StackPane>
                <Label styleClass="form-header-titulo" text="Detalle de Categoría"/>
            </HBox>

            <MFXScrollPane fitToWidth="true" fitToHeight="false"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="form-scroll">
                <VBox styleClass="main-card" spacing="0">

                    <VBox spacing="18">
                        <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>

                        <VBox styleClass="pixel-field-block">
                            <StackPane fx:id="boxCatNombreField" styleClass="pixel-field-container">
                                <HBox styleClass="field-icon-left" alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-tag"/>
                                </HBox>
                                <MFXTextField fx:id="txtCatNombre"
                                              promptText=" "
                                              styleClass="pixel-text-field"
                                              StackPane.alignment="CENTER_LEFT"/>
                                <Label text="Nombre *" styleClass="floating-label" StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                            <Label fx:id="lblCatNombreError" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                        </VBox>

                        <!-- Campo: Descripción -->
                        <VBox spacing="6">
                            <Label text="Descripción" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-sticky-note" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtCatDescripcion"
                                              promptText="Descripción detallada"
                                              styleClass="input-field"
                                              HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <VBox styleClass="pixel-field-block">
                            <StackPane fx:id="boxCatEstadoField" styleClass="pixel-combo-container">
                                <HBox styleClass="field-icon-left" alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-toggle-on"/>
                                </HBox>
                                <MFXComboBox fx:id="cmbCatEstado"
                                             promptText=" "
                                             styleClass="pixel-history-combo"
                                             StackPane.alignment="CENTER_LEFT"/>
                                <Label text="Estado" styleClass="floating-label" StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                        </VBox>

                        <Label fx:id="lblMensajeCategoria"
                               styleClass="form-mensaje"
                               text=""
                               wrapText="true"
                               managed="false"
                               visible="false"/>
                    </VBox>

                    <!-- Footer del formulario -->
                    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form-footer">
                        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                        <MFXButton fx:id="btnGuardarCategoria"
                                maxWidth="Infinity"
                                onAction="#guardarCategoria"
                                styleClass="btn-raised-primary"
                                text="Guardar Categoría"/>

                        <MFXButton fx:id="btnNuevoCategoriaForm"
                                maxWidth="Infinity"
                                onAction="#prepararNuevoCategoria"
                                styleClass="btn-outline-primary"
                                text="Nueva Categoría"/>

                        <MFXButton fx:id="btnEliminarCategoriaForm"
                                disable="true"
                                maxWidth="Infinity"
                                onAction="#eliminarCategoria"
                                styleClass="btn-outline-danger"
                                text="Eliminar"/>
                    </HBox>
                </VBox>
            </MFXScrollPane>
        </VBox>
    </HBox>
</StackPane>
