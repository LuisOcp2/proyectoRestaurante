<?xml version="1.0" encoding="UTF-8"?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import io.github.palexdev.materialfx.controls.*?>

<StackPane
    styleClass="layout-root"
    stylesheets="@../styles/styles.css,@../styles/theme-overrides.css,@../styles/vista-mesas.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.mosqueteros.proyecto_restaurante.controller.InsumoController">

    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

    <HBox alignment="TOP_LEFT" fillHeight="true" maxHeight="Infinity" maxWidth="Infinity" spacing="24">

        <VBox spacing="16" HBox.hgrow="ALWAYS" maxHeight="Infinity">

            <VBox alignment="CENTER_LEFT" spacing="4">
                <Label text="INSUMOS" styleClass="form__label"/>
                <Label styleClass="panel-card__title" text="Insumos"/>
            </VBox>

            <VBox styleClass="panel-card" VBox.vgrow="ALWAYS" maxHeight="Infinity" spacing="0">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="filter-bar">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                    <HBox styleClass="search-wrapper" HBox.hgrow="ALWAYS" minWidth="200">
                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="icon-muted"/>
                        <MFXTextField fx:id="txtBuscarInsumo"
                            promptText="Buscar por nombre o categoría..."
                            styleClass="input,input--search" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <VBox spacing="2">
                        <Label text="Estado" styleClass="form__label"/>
                        <MFXComboBox fx:id="cmbFiltroEstado" promptText="Todos"
                                  prefWidth="120" styleClass="filtro-combo-nativo"/>
                    </VBox>

                    <MFXButton fx:id="btnBuscarInsumo" onAction="#buscarInsumo"
                               styleClass="btn-outline-primary" text="Buscar">
                        <graphic><FontIcon iconLiteral="fas-search" iconSize="12"/></graphic>
                    </MFXButton>

                    <MFXButton fx:id="btnLimpiarFiltroInsumo" onAction="#limpiarFiltros"
                               styleClass="btn-outline-secondary" text="Limpiar">
                        <graphic><FontIcon iconLiteral="fas-sync" iconSize="12"/></graphic>
                    </MFXButton>
                </HBox>

                <HBox styleClass="table__head">
                    <Label text="ID" styleClass="table__col-title" prefWidth="60"/>
                    <Label text="Nombre" styleClass="table__col-title" HBox.hgrow="ALWAYS"/>
                    <Label text="Categoría" styleClass="table__col-title" prefWidth="140"/>
                    <Label text="Unidad" styleClass="table__col-title" prefWidth="100"/>
                    <Label text="Stock" styleClass="table__col-title" prefWidth="100"/>
                    <Label text="Estado" styleClass="table__col-title" prefWidth="80"/>
                </HBox>

                <VBox VBox.vgrow="ALWAYS" spacing="0">
                    <TableView fx:id="tblListaInsumos" styleClass="table,table--data">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colIdInsumo" prefWidth="60" text="ID" />
                            <TableColumn fx:id="colNombre" prefWidth="180" text="NOMBRE" />
                            <TableColumn fx:id="colCategoria" prefWidth="140" text="CATEGORÍA" />
                            <TableColumn fx:id="colUnidad" prefWidth="100" text="UNIDAD" />
                            <TableColumn fx:id="colStock" prefWidth="100" text="STOCK" />
                            <TableColumn fx:id="colEstado" prefWidth="80" text="ESTADO" />
                        </columns>
                    </TableView>

                    <VBox fx:id="boxPlaceholder" alignment="CENTER" spacing="16"
                          visible="true" managed="true" styleClass="state-empty">
                        <FontIcon iconLiteral="fas-leaf" iconSize="48" styleClass="icon-muted"/>
                        <Label text="No hay insumos registrados" styleClass="panel-card__title"/>
                        <Label text="Ajusta los filtros o agrega un nuevo insumo." styleClass="conteo-label"/>
                    </VBox>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="layout-footer">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>
                    <Label fx:id="lblConteoInsumos" styleClass="conteo-label"
                           text="0 insumos encontrados" HBox.hgrow="ALWAYS"/>
                    <MFXButton fx:id="btnNuevoInsumo" onAction="#prepararNuevoInsumo"
                               styleClass="btn-raised-primary" text="Nuevo Insumo">
                        <graphic><FontIcon iconLiteral="fas-plus" iconSize="12"/></graphic>
                    </MFXButton>
                </HBox>
            </VBox>
        </VBox>

        <VBox prefWidth="360" maxWidth="360" minWidth="320" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="form-header">
                <padding><Insets top="20" right="24" bottom="20" left="24" /></padding>
                <StackPane styleClass="form-header-badge">
                    <FontIcon iconLiteral="fas-leaf" iconSize="18"/>
                </StackPane>
                <Label styleClass="form-header-titulo" text="Detalle de Insumo"/>
            </HBox>

            <MFXScrollPane fitToWidth="true" fitToHeight="false"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="form__body">
                <VBox styleClass="panel-card" spacing="0">
                    <VBox spacing="18">
                        <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>

                        <VBox styleClass="pixel-field-block">
                            <StackPane fx:id="boxInsNombreField" styleClass="pixel-field-container">
                                <HBox styleClass="field-icon-left" alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-seedling"/>
                                </HBox>
                                <MFXTextField fx:id="txtInsNombre" promptText=" "
                                              styleClass="pixel-text-field"
                                              StackPane.alignment="CENTER_LEFT"/>
                                <Label text="Nombre" styleClass="floating-label" StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                            <Label fx:id="lblInsNombreError" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                        </VBox>

                        <VBox styleClass="pixel-field-block">
                            <StackPane fx:id="boxInsCategoriaField" styleClass="pixel-combo-container">
                                <HBox styleClass="field-icon-left" alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-tags"/>
                                </HBox>
                                <MFXComboBox fx:id="cmbInsCategoria" promptText=" "
                                             styleClass="pixel-history-combo"
                                             StackPane.alignment="CENTER_LEFT"/>
                                <Label text="Categoría" styleClass="floating-label" StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                        </VBox>

                        <VBox styleClass="pixel-field-block">
                            <StackPane fx:id="boxInsUnidadField" styleClass="pixel-combo-container">
                                <HBox styleClass="field-icon-left" alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-balance-scale"/>
                                </HBox>
                                <MFXComboBox fx:id="cmbInsUnidad" promptText=" "
                                             styleClass="pixel-history-combo"
                                             StackPane.alignment="CENTER_LEFT"/>
                                <Label text="Unidad" styleClass="floating-label" StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Stock" styleClass="form__label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="form__control-wrap">
                                <FontIcon iconLiteral="fas-boxes" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtInsStock" promptText="0"
                                              styleClass="input" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <VBox styleClass="pixel-field-block">
                            <StackPane fx:id="boxInsEstadoField" styleClass="pixel-combo-container">
                                <HBox styleClass="field-icon-left" alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-toggle-on"/>
                                </HBox>
                                <MFXComboBox fx:id="cmbInsEstado" promptText=" "
                                             styleClass="pixel-history-combo"
                                             StackPane.alignment="CENTER_LEFT"/>
                                <Label text="Estado" styleClass="floating-label" StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                        </VBox>

                        <Label fx:id="lblMensajeInsumo" styleClass="form__status" text=""
                               wrapText="true" managed="false" visible="false"/>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form__actions">
                        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                        <MFXButton fx:id="btnGuardarInsumo" maxWidth="Infinity"
                                   onAction="#guardarInsumo" styleClass="btn-raised-primary"
                                   text="Guardar Insumo">
                            <graphic><FontIcon iconLiteral="fas-save" iconSize="12"/></graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnNuevoInsumoForm" maxWidth="Infinity"
                                   onAction="#prepararNuevoInsumo" styleClass="btn-outline-primary"
                                   text="Nuevo Insumo">
                            <graphic><FontIcon iconLiteral="fas-plus" iconSize="12"/></graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnEliminarInsumoForm" disable="true" maxWidth="Infinity"
                                   onAction="#eliminarInsumo" styleClass="btn-outline-danger"
                                   text="Eliminar">
                            <graphic><FontIcon iconLiteral="fas-trash-alt" iconSize="12"/></graphic>
                        </MFXButton>
                    </HBox>
                </VBox>
            </MFXScrollPane>
        </VBox>
    </HBox>
</StackPane>
