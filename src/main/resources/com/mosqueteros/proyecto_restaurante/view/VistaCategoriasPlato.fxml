<?xml version="1.0" encoding="UTF-8"?>
<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
╔════════════════════════════════════════════════════════════════════════════╗
║  VistaCategoriasPlato.fxml  —  CRUD Categorías de Plato                ║
║  Campos mapeados a tabla: categoria_plato (BD restaurante_2026)         ║
╚════════════════════════════════════════════════════════════════════════════╝
-->
<StackPane
    styleClass="root-container"
    stylesheets="@../styles/styles.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.mosqueteros.proyecto_restaurante.controller.CategoriasPlatoController">

    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

    <HBox alignment="TOP_LEFT" fillHeight="true" maxHeight="Infinity" maxWidth="Infinity" spacing="24">

        <!-- COLUMNA IZQUIERDA -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" maxHeight="Infinity">

            <VBox alignment="CENTER_LEFT" spacing="4">
                <Label text="CATEGORÍAS DE PLATO" styleClass="input-label"/>
                <Label styleClass="titulo-texto" text="Categorías de Plato"/>
            </VBox>

            <VBox styleClass="main-card" VBox.vgrow="ALWAYS" maxHeight="Infinity" spacing="0">

                <!-- Barra filtros -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="filter-bar">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                    <HBox styleClass="search-wrapper" HBox.hgrow="ALWAYS" minWidth="200">
                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="icon-muted"/>
                        <MFXTextField fx:id="txtBuscarCategoria"
                            promptText="Buscar por nombre o descripción..."
                            styleClass="search-field" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <VBox spacing="2">
                        <Label text="Estado" styleClass="input-label"/>
                        <ComboBox fx:id="cmbFiltroEstado" promptText="Todos los estados"
                                  prefWidth="120" styleClass="filtro-combo-nativo"/>
                    </VBox>

                    <MFXButton fx:id="btnBuscarCategoria" onAction="#buscarCategoria"
                               styleClass="btn-outline-primary" text="Buscar">
                        <graphic><FontIcon iconLiteral="fas-search" iconSize="12"/></graphic>
                    </MFXButton>

                    <MFXButton fx:id="btnLimpiarFiltroCategoria" onAction="#limpiarFiltros"
                               styleClass="btn-outline-secondary" text="Limpiar">
                        <graphic><FontIcon iconLiteral="fas-sync" iconSize="12"/></graphic>
                    </MFXButton>
                </HBox>

                <!-- Cabecera -->
                <HBox styleClass="table-header-row">
                    <Label text="ID" styleClass="col-header" prefWidth="60"/>
                    <Label text="Nombre" styleClass="col-header" HBox.hgrow="ALWAYS"/>
                    <Label text="Descripción" styleClass="col-header" HBox.hgrow="ALWAYS"/>
                    <Label text="Estado" styleClass="col-header" prefWidth="80"/>
                </HBox>

                <!-- Tabla -->
                <VBox VBox.vgrow="ALWAYS" spacing="0">
                    <TableView fx:id="tblListaCategorias" styleClass="mesas-table">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colIdCategoria" prefWidth="60" text="ID" />
                            <TableColumn fx:id="colNombre" prefWidth="150" text="NOMBRE" />
                            <TableColumn fx:id="colDescripcion" prefWidth="200" text="DESCRIPCIÓN" />
                            <TableColumn fx:id="colEstado" prefWidth="80" text="ESTADO" />
                        </columns>
                    </TableView>

                    <VBox fx:id="boxPlaceholder" alignment="CENTER" spacing="16"
                          visible="true" managed="true" styleClass="empty-state">
                        <FontIcon iconLiteral="fas-folder" iconSize="48" styleClass="icon-muted"/>
                        <Label text="No hay categorías de plato registradas" styleClass="titulo-texto"/>
                        <Label text="Ajusta los filtros o agrega una nueva categoría." styleClass="conteo-label"/>
                    </VBox>
                </VBox>

                <!-- Footer tabla -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="table-footer">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>
                    <Label fx:id="lblConteoCategorias" styleClass="conteo-label"
                           text="0 categorías encontradas" HBox.hgrow="ALWAYS"/>
                    <MFXButton fx:id="btnNuevoCategoria" onAction="#prepararNuevoCategoria"
                               styleClass="btn-raised-primary" text="Nueva Categoría">
                        <graphic><FontIcon iconLiteral="fas-plus" iconSize="12"/></graphic>
                    </MFXButton>
                </HBox>
            </VBox>
        </VBox>

        <!-- COLUMNA DERECHA  —  Formulario -->
        <VBox prefWidth="360" maxWidth="360" minWidth="320" spacing="0">

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="form-header">
                <padding><Insets top="20" right="24" bottom="20" left="24" /></padding>
                <StackPane styleClass="form-header-badge">
                    <FontIcon iconLiteral="fas-folder" iconSize="18"/>
                </StackPane>
                <Label styleClass="form-header-titulo" text="Detalle de Categoría"/>
            </HBox>

            <!-- ScrollPane con import corregido -->
            <ScrollPane fitToWidth="true" fitToHeight="false"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="form-scroll">
                <VBox styleClass="main-card" spacing="0">

                    <VBox spacing="18">
                        <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>

                        <!-- Campo: Nombre -->
                        <VBox spacing="6">
                            <Label text="Nombre" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-tags" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtCatNombre" promptText="Ej. Entradas"
                                              styleClass="input-field" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Descripción -->
                        <VBox spacing="6">
                            <Label text="Descripción" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-sticky-note" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtCatDescripcion" promptText="Descripción detallada"
                                              styleClass="input-field" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Campo: Estado -->
                        <VBox spacing="6">
                            <Label text="Estado" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                                <FontIcon iconLiteral="fas-toggle-on" iconSize="14" styleClass="icon-muted"/>
                                <MFXComboBox fx:id="cmbCatEstado" promptText="Seleccionar estado"
                                             styleClass="input-combo" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <Label fx:id="lblMensajeCategoria" styleClass="form-mensaje" text=""
                               wrapText="true" managed="false" visible="false"/>
                    </VBox>

                    <!-- Footer formulario -->
                    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form-footer">
                        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                        <MFXButton fx:id="btnGuardarCategoria" maxWidth="Infinity"
                                   onAction="#guardarCategoria" styleClass="btn-raised-primary"
                                   text="Guardar Categoría">
                            <graphic><FontIcon iconLiteral="fas-save" iconSize="12"/></graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnNuevoCategoriaForm" maxWidth="Infinity"
                                   onAction="#prepararNuevoCategoria" styleClass="btn-outline-primary"
                                   text="Nueva Categoría">
                            <graphic><FontIcon iconLiteral="fas-plus" iconSize="12"/></graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnEliminarCategoriaForm" disable="true" maxWidth="Infinity"
                                   onAction="#eliminarCategoria" styleClass="btn-outline-danger"
                                   text="Eliminar">
                            <graphic><FontIcon iconLiteral="fas-trash-alt" iconSize="12"/></graphic>
                        </MFXButton>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</StackPane>