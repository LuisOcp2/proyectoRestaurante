<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXScrollPane?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
  Cali Delights — main.fxml  v3.0  (Shell Inmersivo MaterialFX)
  Topbar: gradiente índigo→cian  |  Sidebar: blanco 260px colapsable
  Acento: #FF6933  |  Fondo: #F8F9FA
-->

<BorderPane styleClass="shell-root"
            stylesheets="@../main-shell.css,@../styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mosqueteros.proyecto_restaurante.controller.MainController">

    <!-- ══════════════════════════════════════════════════════════════
         TOPBAR — gradiente índigo → cian, 60px alto
         ══════════════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="topbar">

            <!-- Botón hamburger -->
            <MFXButton fx:id="btnHamburger"
                       onAction="#toggleSidebar"
                       styleClass="btn-hamburger"
                       text="☰" />

            <!-- Marca en topbar (sólo visible en mini-sidebar) -->
            <Label fx:id="lblTopbarBrand"
                   styleClass="topbar-brand"
                   text="🍽  Cali Delights"
                   visible="false"
                   managed="false" />

            <!-- Buscador global con icono -->
            <HBox alignment="CENTER_LEFT" styleClass="topbar-search-wrapper" spacing="6">
                <Label styleClass="topbar-search-icon" text="🔍" />
                <MFXTextField fx:id="txtBusqueda"
                              floatMode="DISABLED"
                              promptText="Buscar..."
                              styleClass="topbar-search" />
            </HBox>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Avatar + nombre + rol -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane styleClass="avatar-circle">
                    <Label fx:id="lblAvatar" styleClass="avatar-initials" text="?" />
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label fx:id="lblNombreUsuario" styleClass="topbar-username" text="Usuario" />
                    <Label fx:id="lblRolUsuario"    styleClass="topbar-rol"      text="Cargando…" />
                </VBox>
            </HBox>

            <!-- Botón Cerrar Sesión -->
            <MFXButton fx:id="btnCerrarSesion"
                       onAction="#cerrarSesion"
                       styleClass="btn-logout"
                       text="Salir">
                <graphic>
                    <FontIcon iconLiteral="fas-power-off" iconSize="16" iconColor="white"/>
                </graphic>
                <HBox.margin><Insets left="8" right="8" /></HBox.margin>
            </MFXButton>

        </HBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════════
         CENTRO: Sidebar + Contenido
         ══════════════════════════════════════════════════════════════ -->
    <center>
        <HBox VBox.vgrow="ALWAYS">

            <!-- ── SIDEBAR ── -->
            <VBox fx:id="sidebar"
                  styleClass="sidebar"
                  VBox.vgrow="ALWAYS">

                <!-- Cabecera de marca -->
                <VBox fx:id="sidebarBrandBox"
                      alignment="CENTER"
                      spacing="6"
                      styleClass="sidebar-brand">
                    <StackPane styleClass="sidebar-logo-circle">
                        <Label styleClass="sidebar-logo-icon" text="🍽" />
                    </StackPane>
                    <Label fx:id="lblSidebarBrand"
                           styleClass="sidebar-brand-name"
                           text="Cali Delights" />
                    <Label fx:id="lblSidebarSub"
                           styleClass="sidebar-brand-sub"
                           text="Gestión de restaurante" />
                </VBox>

                <!-- Menú con scroll MFX -->
                <MFXScrollPane fx:id="sidebarScroll"
                               fitToWidth="true"
                               styleClass="sidebar-scroll"
                               VBox.vgrow="ALWAYS">

                    <VBox spacing="2">
                        <padding><Insets bottom="20" left="8" right="8" top="8" /></padding>

                        <!-- ══════════════════════════════════════════
                             BOTÓN: DASHBOARD
                             ══════════════════════════════════════════ -->
                        <MFXButton fx:id="btnDashboard"
                                   text="Dashboard"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarDashboard">
                            <graphic>
                                <FontIcon iconLiteral="fas-chart-bar" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <!-- ══════════════════════════════════════════
                             SECCIÓN: LUIS — Pedidos y Comandas
                             ══════════════════════════════════════════ -->
                        <Label fx:id="seccionLuis" text="PEDIDOS Y COMANDAS"
                               styleClass="menu-section"/>

                        <MFXButton fx:id="btnMesas"
                                   text="Mesas"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaMesas">
                            <graphic>
                                <FontIcon iconLiteral="fas-chair" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnAreasMesa"
                                   text="Áreas de Mesa"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaAreasMesa">
                            <graphic>
                                <FontIcon iconLiteral="fas-map-marked-alt" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnPlatos"
                                   text="Platos"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaPlatos">
                            <graphic>
                                <FontIcon iconLiteral="fas-utensils" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnCategoriasPlato"
                                   text="Categorías Plato"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaCategoriasPlato">
                            <graphic>
                                <FontIcon iconLiteral="fas-folder" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnPedidos"
                                   text="Pedidos"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaPedidos">
                            <graphic>
                                <FontIcon iconLiteral="fas-clipboard-list" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnComandas"
                                   text="Cocina / Comandas"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaComandas">
                            <graphic>
                                <FontIcon iconLiteral="fas-fire" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <!-- ══════════════════════════════════════════
                             SECCIÓN: SEBASTIÁN — Egresos y Seguridad
                             ══════════════════════════════════════════ -->
                        <Label fx:id="seccionSebastian" text="EGRESOS"
                               styleClass="menu-section"/>

                        <MFXButton fx:id="btnEgresos"
                                   text="Egresos"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaEgresos">
                            <graphic>
                                <FontIcon iconLiteral="fas-money-bill-wave" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnConceptoEgreso"
                                   text="Concepto Egreso"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaConceptoEgreso">
                            <graphic>
                                <FontIcon iconLiteral="fas-tag" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnFormaPago"
                                   text="Forma de Pago"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaFormaPago">
                            <graphic>
                                <FontIcon iconLiteral="fas-credit-card" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <!-- ══════════════════════════════════════════
                             SECCIÓN: ANGIE — Facturación y Roles
                             ══════════════════════════════════════════ -->
                        <Label fx:id="seccionAngie" text="FACTURACIÓN"
                               styleClass="menu-section"/>

                        <MFXButton fx:id="btnReciboCaja"
                                   text="Recibos de Caja"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaReciboCaja">
                            <graphic>
                                <FontIcon iconLiteral="fas-file-invoice-dollar" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnClientes"
                                   text="Clientes"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaClientes">
                            <graphic>
                                <FontIcon iconLiteral="fas-user" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnPerfiles"
                                   text="Perfiles / Roles"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaPerfiles">
                            <graphic>
                                <FontIcon iconLiteral="fas-id-badge" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnUsuarios"
                                   text="Usuarios"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaUsuarios">
                            <graphic>
                                <FontIcon iconLiteral="fas-users" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <!-- ══════════════════════════════════════════
                             SECCIÓN: NICOLÁS — Inventario / PQRS
                             ══════════════════════════════════════════ -->
                        <Label fx:id="seccionNicolas" text="INVENTARIO / PQRS"
                               styleClass="menu-section"/>

                        <MFXButton fx:id="btnInventarioLog"
                                   text="Movimientos Bodega"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaInventarioLog">
                            <graphic>
                                <FontIcon iconLiteral="fas-box" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnInsumos"
                                   text="Insumos"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaInsumos">
                            <graphic>
                                <FontIcon iconLiteral="fas-leaf" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnPresentacion"
                                   text="Presentaciones"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaPresentacion">
                            <graphic>
                                <FontIcon iconLiteral="fas-balance-scale" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnCategoriaInsumo"
                                   text="Cat. Insumo"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaCategoriaInsumo">
                            <graphic>
                                <FontIcon iconLiteral="fas-folder" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnPQRS"
                                   text="PQRS"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaPQRS">
                            <graphic>
                                <FontIcon iconLiteral="fas-comment-alt" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                        <!-- ══════════════════════════════════════════
                             SECCIÓN: CONFIGURACIÓN GENERAL
                             ══════════════════════════════════════════ -->
                        <Label fx:id="seccionConfiguracion" text="CONFIGURACIÓN"
                               styleClass="menu-section"/>

                        <MFXButton fx:id="btnSedes"
                                   text="Sedes"
                                   styleClass="menu-btn"
                                   maxWidth="Infinity"
                                   onAction="#mostrarVistaSedes">
                            <graphic>
                                <FontIcon iconLiteral="fas-building" iconSize="18" styleClass="menu-icon"/>
                            </graphic>
                        </MFXButton>

                    </VBox>
                </MFXScrollPane>

            </VBox>

            <!-- ── ÁREA DE CONTENIDO ── -->
            <StackPane fx:id="contenidoPrincipal"
                       styleClass="content-area"
                       HBox.hgrow="ALWAYS"
                       VBox.vgrow="ALWAYS">

                <!-- Panel de bienvenida por defecto -->
                <VBox alignment="CENTER" spacing="20" styleClass="welcome-panel">
                    <Label fx:id="lblBienvenida"
                           styleClass="welcome-title"
                           text="¡Bienvenido!" />
                    <Label fx:id="lblRol"
                           styleClass="welcome-subtitle"
                           text="" />
                    <Label styleClass="welcome-hint"
                           text="Selecciona una opción del menú lateral" />
                </VBox>

            </StackPane>

        </HBox>
    </center>

</BorderPane>
