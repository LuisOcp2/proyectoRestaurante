<?xml version="1.0" encoding="UTF-8"?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import io.github.palexdev.materialfx.controls.*?>

<!--
╔════════════════════════════════════════════════════════════════════════════╗
║  VistaConceptoEgreso.fxml  —  CRUD Conceptos de Egreso                 ║
║  Campos mapeados a tabla: concepto_egreso (BD restaurante_2026)         ║
╚════════════════════════════════════════════════════════════════════════════╝
-->
<StackPane
    styleClass="layout-root"
    stylesheets="@../styles/styles.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.mosqueteros.proyecto_restaurante.controller.ConceptoEgresoController">

    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

    <HBox alignment="TOP_LEFT" fillHeight="true" maxHeight="Infinity" maxWidth="Infinity" spacing="24">

        <!-- COLUMNA IZQUIERDA -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" maxHeight="Infinity">

            <VBox alignment="CENTER_LEFT" spacing="4">
                <Label text="CONCEPTOS DE EGRESO" styleClass="form__label"/>
                <Label styleClass="panel-card__title" text="Conceptos de Egreso"/>
            </VBox>

            <VBox styleClass="panel-card" VBox.vgrow="ALWAYS" maxHeight="Infinity" spacing="0">

                <!-- Barra filtros -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="filter-bar">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                    <HBox styleClass="search-wrapper" HBox.hgrow="ALWAYS" minWidth="200">
                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="icon-muted"/>
                        <MFXTextField fx:id="txtBuscarConcepto"
                            promptText="Buscar por nombre o descripción..."
                            styleClass="input,input--search" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <VBox spacing="2">
                        <Label text="Estado" styleClass="form__label"/>
                        <MFXComboBox fx:id="cmbFiltroEstado" promptText="Todos los estados"
                                  prefWidth="120" styleClass="filtro-combo-nativo"/>
                    </VBox>

                    <MFXButton fx:id="btnBuscarConcepto" onAction="#buscarConcepto"
                               styleClass="btn-outline-primary" text="Buscar">
                        <graphic><FontIcon iconLiteral="fas-search" iconSize="12"/></graphic>
                    </MFXButton>

                    <MFXButton fx:id="btnLimpiarFiltroConcepto" onAction="#limpiarFiltros"
                               styleClass="btn-outline-secondary" text="Limpiar">
                        <graphic><FontIcon iconLiteral="fas-sync" iconSize="12"/></graphic>
                    </MFXButton>
                </HBox>

                <!-- Cabecera -->
                <HBox styleClass="table__head">
                    <Label text="ID" styleClass="table__col-title" prefWidth="60"/>
                    <Label text="Nombre" styleClass="table__col-title" HBox.hgrow="ALWAYS"/>
                    <Label text="Descripción" styleClass="table__col-title" HBox.hgrow="ALWAYS"/>
                    <Label text="Estado" styleClass="table__col-title" prefWidth="80"/>
                </HBox>

                <!-- Tabla -->
                <VBox VBox.vgrow="ALWAYS" spacing="0">
                    <TableView fx:id="tblListaConceptos" styleClass="table,table--data">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colIdConcepto" prefWidth="60" text="ID" />
                            <TableColumn fx:id="colNombre" prefWidth="150" text="NOMBRE" />
                            <TableColumn fx:id="colDescripcion" prefWidth="200" text="DESCRIPCIÓN" />
                            <TableColumn fx:id="colEstado" prefWidth="80" text="ESTADO" />
                        </columns>
                    </TableView>

                    <VBox fx:id="boxPlaceholder" alignment="CENTER" spacing="16"
                          visible="true" managed="true" styleClass="state-empty">
                        <FontIcon iconLiteral="fas-tag" iconSize="48" styleClass="icon-muted"/>
                        <Label text="No hay conceptos de egreso registrados" styleClass="panel-card__title"/>
                        <Label text="Ajusta los filtros o agrega un nuevo concepto." styleClass="conteo-label"/>
                    </VBox>
                </VBox>

                <!-- Footer tabla -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="layout-footer">
                    <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>
                    <Label fx:id="lblConteoConceptos" styleClass="conteo-label"
                           text="0 conceptos encontrados" HBox.hgrow="ALWAYS"/>
                    <MFXButton fx:id="btnNuevoConcepto" onAction="#prepararNuevoConcepto"
                               styleClass="btn-raised-primary" text="Nuevo Concepto">
                        <graphic><FontIcon iconLiteral="fas-plus" iconSize="12"/></graphic>
                    </MFXButton>
                </HBox>
            </VBox>
        </VBox>

        <!-- COLUMNA DERECHA  —  Formulario -->
        <VBox prefWidth="360" maxWidth="360" minWidth="320" spacing="0">

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="form-header">
                <padding><Insets top="20" right="24" bottom="20" left="24" /></padding>
                <StackPane styleClass="form-header-badge">
                    <FontIcon iconLiteral="fas-tag" iconSize="18"/>
                </StackPane>
                <Label styleClass="form-header-titulo" text="Detalle de Concepto"/>
            </HBox>

            <!-- MFXScrollPane con import corregido -->
            <MFXScrollPane fitToWidth="true" fitToHeight="false"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="form__body">
                <VBox styleClass="panel-card" spacing="0">

                    <VBox spacing="18">
                        <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>

                        <!-- Campo Pixel Perfect: Nombre -->
                        <VBox styleClass="pixel-field-block">
                            <StackPane fx:id="boxConNombreField" styleClass="pixel-field-container">
                                <HBox styleClass="field-icon-left" alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-tag"/>
                                </HBox>
                                <MFXTextField fx:id="txtConNombre" promptText=" "
                                              styleClass="pixel-text-field"
                                              StackPane.alignment="CENTER_LEFT"/>
                                <Label text="Nombre" styleClass="floating-label" StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                            <Label fx:id="lblConNombreError" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                        </VBox>

                        <!-- Campo: Descripción -->
                        <VBox spacing="6">
                            <Label text="Descripción" styleClass="form__label"/>
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="form__control-wrap">
                                <FontIcon iconLiteral="fas-sticky-note" iconSize="14" styleClass="icon-muted"/>
                                <MFXTextField fx:id="txtConDescripcion" promptText="Descripción detallada"
                                              styleClass="input" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <!-- Combo Pixel Perfect: Estado -->
                        <VBox styleClass="pixel-field-block">
                            <StackPane fx:id="boxConEstadoField" styleClass="pixel-combo-container">
                                <HBox styleClass="field-icon-left" alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-toggle-on"/>
                                </HBox>
                                <MFXComboBox fx:id="cmbConEstado" promptText=" "
                                             styleClass="pixel-history-combo"
                                             StackPane.alignment="CENTER_LEFT"/>
                                <Label text="Estado" styleClass="floating-label" StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                        </VBox>

                        <Label fx:id="lblMensajeConcepto" styleClass="form__status" text=""
                               wrapText="true" managed="false" visible="false"/>
                    </VBox>

                    <!-- Footer formulario -->
                    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form__actions">
                        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

                        <MFXButton fx:id="btnGuardarConcepto" maxWidth="Infinity"
                                   onAction="#guardarConcepto" styleClass="btn-raised-primary"
                                   text="Guardar Concepto">
                            <graphic><FontIcon iconLiteral="fas-save" iconSize="12"/></graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnNuevoConceptoForm" maxWidth="Infinity"
                                   onAction="#prepararNuevoConcepto" styleClass="btn-outline-primary"
                                   text="Nuevo Concepto">
                            <graphic><FontIcon iconLiteral="fas-plus" iconSize="12"/></graphic>
                        </MFXButton>

                        <MFXButton fx:id="btnEliminarConceptoForm" disable="true" maxWidth="Infinity"
                                   onAction="#eliminarConcepto" styleClass="btn-outline-danger"
                                   text="Eliminar">
                            <graphic><FontIcon iconLiteral="fas-trash-alt" iconSize="12"/></graphic>
                        </MFXButton>
                    </HBox>
                </VBox>
            </MFXScrollPane>
        </VBox>
    </HBox>
</StackPane>
